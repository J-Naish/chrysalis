{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "WebFetch",
      "WebSearch",
      "Skill",
      "NotebookEdit",
      "NotebookRead",
      "MCP",
      "ExitPlanMode",
      "Edit",
      "Write"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Task completed\" with title \"Claude Code\" sound name \"$Glass\"'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Permission requested\" with title \"Claude Code\" sound name \"Blow\"'"
          }
        ]
      }
    ]
  }
}
